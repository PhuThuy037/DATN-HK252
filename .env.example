# =========================
# APP
# =========================
APP_NAME=datn-phase2-rag
APP_ENV=development
DEBUG=true
# =========================
# AUTH / JWT
# =========================
SECRET_KEY=change-me-now
JWT_SECRET_KEY=change-me-now
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# =========================
# Timezone
# =========================
TZ=Asia/Ho_Chi_Minh

# ASGI app path
ASGI_APP=app.main:app

# =========================
# PORTS (host ports)
# =========================
API_PORT=8000
DB_PORT=5433
REDIS_PORT=6379
PGADMIN_PORT=5050

# =========================
# POSTGRES
# =========================
POSTGRES_USER=app
POSTGRES_PASSWORD=app123
POSTGRES_DB=datn_phase2

# IMPORTANT: host is "db" because API is in Docker network
DATABASE_URL=postgresql+psycopg://app:app123@db:5432/datn_phase2

# =========================
# REDIS
# =========================
REDIS_URL=redis://redis:6379/0
POLICY_INGEST_QUEUE_NAME=policy_ingest_jobs
RULE_DUPLICATE_TOP_K=5
RULE_DUPLICATE_EXACT_THRESHOLD=0.92
RULE_DUPLICATE_NEAR_THRESHOLD=0.82
RULE_DUPLICATE_EMBED_MODEL=local-hash-1536-v1

# =========================
# GUNICORN (prod/demo)
# =========================
WORKERS=2
TIMEOUT=60

# =========================
# PGADMIN
# =========================
PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=admin123

# =========================
# LLM Providers
# =========================
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_MODEL=gemini-2.5-flash
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
NON_EMBEDDING_LLM_PROVIDER=groq
NON_EMBEDDING_LLM_TIMEOUT_SECONDS=12

CHAT_PROVIDER=groq
GOOGLE_API_KEY=x
GROQ_API_KEY=x
DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.
DEFAULT_RULESET_ADMIN_EMAIL=admin_thuynp@gmail.com

# =========================
# CORS
# =========================
# Comma-separated origins for frontend apps
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Note: when CORS_ALLOWED_ORIGINS=* then credentials will be forced false
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

